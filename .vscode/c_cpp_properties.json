{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/gcc",
      "cStandard": "gnu17",
      "cppStandard": "gnu++17",
      "intelliSenseMode": "linux-gcc-x64",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/header",
        "${workspaceFolder}/lib"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/header",
          "${workspaceFolder}/lib"
        ],
        "limitSymbolsToIncludedHeaders": true
      },
      "configurationProvider": "ms-vscode.cpptools"
    }
  ]
}
